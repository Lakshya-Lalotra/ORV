# --- App + Prisma (PostgreSQL — Neon, Supabase, Docker, etc.) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Reader gate — server-only. Comma-separated names when ORV_BYPASS_AUTH is not 1.
ORV_ALLOWED_NAMES=reader-one,reader-two
# ORV_BYPASS_AUTH=1
# Staging/QA: orv-reader-key alone is not enough — need orv-prologue-complete (set at end of prologue).
# After "Continue", the app is not frozen. To re-test the full prologue: open /auth?replay=1
# ORV_ALWAYS_PROLOGUE=1

ORV_AUTH_AUDIT_SALT=long-random-string
# ORV_AUTH_AUDIT=0

CRON_SECRET=generate-a-long-random-string

ORV_MANHWA_INCREMENTAL_MAX=5
ORV_MANHWA_SCRAPE_TO_CAP=400
ORV_MANHWA_BASE_URL=https://www.mangaread.org/manga/omniscient-readers-viewpoint/chapter-0/

# OPENAI_API_KEY=
# OPENAI_SCENARIO_MODEL=gpt-4o-mini

# --- Static assets + content JSON on R2 (mirror local public/ *and* content/) ---
# Browser URL, no trailing slash. Rebuild after changing (NEXT_PUBLIC_* is compile-time).
# If your objects are under a prefix in the bucket (e.g. orv/panels/...), put that in the base:
#   NEXT_PUBLIC_ORV_BLOB_BASE=https://pub-xxxxxxxx.r2.dev/orv
# If the bucket root = your public tree, omit the extra path segment.
#
# When this is set, the server lazy-fetches these files from R2 (Next revalidate
# cache, 1h) with a local-fs fallback for dev:
#   content/prologue.json            prologue copy for /auth
#   content/manhwa-map.json          slug -> panel image URL list
#   content/sequel/index.json
#   content/sequel/ch_<N>.json       per-chapter bodies
#   content/side/index.json
#   content/side/ch_<N>.json
# Upload the same tree you have locally under `content/` after `ingest:sequel` /
# `ingest:side` and `build:manhwa-map`. Panel images go under `panels/...` as before.
# Manhwa image URLs inside manhwa-map.json can stay as `/panels/...`; the server
# prefixes NEXT_PUBLIC_ORV_BLOB_BASE automatically via publicAssetUrl.
#
# NEXT_PUBLIC_ORV_BLOB_BASE=https://pub-xxxxxxxx.r2.dev
# Optional per-file override (highest priority):
# NEXT_PUBLIC_ORV_REVEAL_VIDEO_URL=
# NEXT_PUBLIC_ORV_REVEAL_AUDIO_URL=
# NEXT_PUBLIC_ORV_FINALE_HERO_URL=
#
# EPUBs in R2 (content/… in bucket) are for backup / CLI; ingest still uses local content/*.epub
#   npm run upload:r2-epub

# --- Optional: Neon pooled URL + direct URL for migrations (add `directUrl` in schema.prisma first) ---
# DIRECT_URL="postgresql://..."

# =============================================================================
# CLI / ingest / scrape scripts only (`npm run setup`, `ingest:*`, `scrape:*`)
# Not read by `next start`. Export in your shell or duplicate into a local `.env.scripts` if you use tooling that loads multiple files.
# =============================================================================
# ORV_INGEST_BITTU=1
# ORV_FETCH_ARCHIVE=1
# ORV_TXT_URL=https://ia800403.us.archive.org/4/items/omniscient-readers-viewpoint-sing-shong-singsyong/...
# ORV_TXT_PATH=
# ORV_PDF_PATH=
# ORV_EPUB_PATH=
# ORV_SIDE_EPUB=./content/orv_side.epub
# ORV_SKIP_FIRST_CHAPTERS=
# ORV_MAX_CHAPTERS=
# ORV_EPUB_MODE=spine
# ORV_BITTU_DELAY_MS=85
# ORV_ATTACH_BITTU_ILLUSTRATIONS=1
# ORV_BITTU_ILLUSTRATIONS=
# ORV_PANELS_SOURCE=
# ORV_PUBLIC_ORIGIN=http://localhost:3000
# ORV_SCRAPE_UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
