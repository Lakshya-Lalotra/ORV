# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local SQLite database files (migrations stay tracked)
/prisma/dev.db
/prisma/**/*.db

/src/generated/prisma

# Local licensed PDFs, OCR text, and panel URL maps (do not commit)
/content/*.pdf
/content/*.txt
/content/*.epub
/content/manhwa-map.json
# Local panel masters (often large); use npm run build:manhwa-map -- --sync → public/panels
/content/panels
# Published panel JPEGs (can be GB+); deploy via CI/scrape or sync separately — do not commit
/public/panels

# local next logs
.next-start*.log
tmp_*.html
